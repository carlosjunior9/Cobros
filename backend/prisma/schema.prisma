generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Rol {
  id       Int       @id @default(autoincrement())
  nombre   RolNombre @unique
  usuarios Usuario[]

  @@map("rol")
}

model Usuario {
  id                    Int                     @id @default(autoincrement())
  nombre                String
  apellido              String
  correo                String                  @unique
  password              String
  pais                  String?
  avatar                String?
  genero                Genero?
  direccion             String?
  activo                Boolean                 @default(true)
  fechaRegistro         DateTime                @default(now())
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  rolId                 Int
  bitacora_pagos        bitacora_pagos[]
  cambioEmails          CambioEmail[]
  inmuebles             Inmueble[]
  notificaciones        Notificacion[]
  perfil                Perfil?
  publicaciones         Publicacion[]
  sesiones              Sesion[]
  suscripciones_activas suscripciones_activas[]
  telefonos             Telefono[]
  transacciones         transacciones[]
  rol                   Rol                     @relation(fields: [rolId], references: [id])
  verificacion_pago     verificacion_pago[]
  visitas               Visitor[]

  @@index([correo])
  @@map("usuario")
}

model Telefono {
  id         Int     @id @default(autoincrement())
  codigoPais String
  numero     String
  principal  Boolean @default(false)
  usuarioId  Int
  usuario    Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("telefono")
}

model Sesion {
  id              Int      @id @default(autoincrement())
  token           String   @unique
  fechaInicio     DateTime @default(now())
  fechaExpiracion DateTime
  estado          Boolean  @default(true)
  usuarioId       Int
  usuario         Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("sesion")
}

model Notificacion {
  id            Int       @id @default(autoincrement())
  titulo        String
  mensaje       String
  leida         Boolean   @default(false)
  fechaCreacion DateTime  @default(now())
  fechaLectura  DateTime?
  eliminada     Boolean   @default(false)
  usuarioId     Int
  usuario       Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("notificacion")
}

model CambioEmail {
  id           Int       @id @default(autoincrement())
  emailNuevo   String
  token        String    @unique
  expiraEn     DateTime
  creadoEn     DateTime  @default(now())
  completadoEn DateTime?
  usuarioId    Int
  usuario      Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("cambio_email")
}

model Perfil {
  id             Int     @id @default(autoincrement())
  nombreCompleto String
  datos          Json?
  usuarioId      Int     @unique
  usuario        Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("perfil")
}

model Inmueble {
  id               Int                @id @default(autoincrement())
  titulo           String
  tipoAccion       TipoAccion
  categoria        Categoria?
  precio           Decimal            @db.Decimal(12, 2)
  superficieM2     Decimal?           @db.Decimal(10, 2)
  nroCuartos       Int?
  nroBanos         Int?
  descripcion      String?
  estado           EstadoInmueble     @default(ACTIVO)
  fechaPublicacion DateTime           @default(now())
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  propietarioId    Int
  propietario      Usuario            @relation(fields: [propietarioId], references: [id], onDelete: Cascade)
  etiquetas        InmuebleEtiqueta[]
  marcadores       MarcadorMapa[]
  publicaciones    Publicacion[]
  ubicacion        UbicacionInmueble?

  @@index([propietarioId])
  @@map("inmueble")
}

model UbicacionInmueble {
  id                 Int                @id @default(autoincrement())
  latitud            Decimal            @db.Decimal(10, 7)
  longitud           Decimal            @db.Decimal(10, 7)
  direccion          String?
  zona               String?
  ciudad             String
  inmuebleId         Int                @unique
  ubicacionMaestraId Int?
  marcadores         MarcadorMapa[]
  inmueble           Inmueble           @relation(fields: [inmuebleId], references: [id], onDelete: Cascade)
  ubicacion_maestra  ubicacion_maestra? @relation(fields: [ubicacionMaestraId], references: [id])

  @@map("ubicacion_inmueble")
}

model Etiqueta {
  id        Int                @id @default(autoincrement())
  nombre    String             @unique
  inmuebles InmuebleEtiqueta[]

  @@map("etiqueta")
}

model InmuebleEtiqueta {
  inmuebleId Int
  etiquetaId Int
  etiqueta   Etiqueta @relation(fields: [etiquetaId], references: [id], onDelete: Cascade)
  inmueble   Inmueble @relation(fields: [inmuebleId], references: [id], onDelete: Cascade)

  @@id([inmuebleId, etiquetaId])
  @@map("inmueble_etiqueta")
}

model Publicacion {
  id               Int               @id @default(autoincrement())
  titulo           String
  descripcion      String?
  estado           EstadoPublicacion @default(ACTIVA)
  fechaPublicacion DateTime          @default(now())
  usuarioId        Int
  inmuebleId       Int
  multimedia       Multimedia[]
  inmueble         Inmueble          @relation(fields: [inmuebleId], references: [id], onDelete: Cascade)
  usuario          Usuario           @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("publicacion")
}

model Multimedia {
  id            Int            @id @default(autoincrement())
  url           String
  tipo          TipoMultimedia
  pesoMb        Decimal?       @db.Decimal(8, 2)
  publicacionId Int
  publicacion   Publicacion    @relation(fields: [publicacionId], references: [id], onDelete: Cascade)

  @@map("multimedia")
}

model MarcadorMapa {
  id            Int               @id @default(autoincrement())
  tipo          TipoMarcador
  esVisible     Boolean           @default(true)
  nivelZ        Int?
  inmuebleId    Int
  ubicacionId   Int
  grupos        DetalleGrupo[]
  interacciones InteraccionMapa[]
  inmueble      Inmueble          @relation(fields: [inmuebleId], references: [id], onDelete: Cascade)
  ubicacion     UbicacionInmueble @relation(fields: [ubicacionId], references: [id], onDelete: Cascade)

  @@map("marcador_mapa")
}

model GrupoMarcadores {
  id                Int            @id @default(autoincrement())
  latitudCentro     Decimal        @db.Decimal(10, 7)
  longitudCentro    Decimal        @db.Decimal(10, 7)
  cantidadInmuebles Int
  nivelColor        String?
  nivelZoom         Int
  radioKm           Decimal?       @db.Decimal(10, 2)
  actualizadoEn     DateTime       @updatedAt
  marcadores        DetalleGrupo[]

  @@map("grupo_marcadores")
}

model DetalleGrupo {
  grupoId    Int
  marcadorId Int
  grupo      GrupoMarcadores @relation(fields: [grupoId], references: [id], onDelete: Cascade)
  marcador   MarcadorMapa    @relation(fields: [marcadorId], references: [id], onDelete: Cascade)

  @@id([grupoId, marcadorId])
  @@map("detalle_grupo")
}

model SesionMapa {
  id              Int               @id @default(autoincrement())
  token           String            @unique
  limiteNorte     Decimal?          @db.Decimal(10, 7)
  limiteSur       Decimal?          @db.Decimal(10, 7)
  limiteEste      Decimal?          @db.Decimal(10, 7)
  limiteOeste     Decimal?          @db.Decimal(10, 7)
  nivelZoom       Int
  latitudCentro   Decimal?          @db.Decimal(10, 7)
  longitudCentro  Decimal?          @db.Decimal(10, 7)
  iniciadoEn      DateTime          @default(now())
  ultimaActividad DateTime          @updatedAt
  interacciones   InteraccionMapa[]

  @@map("sesion_mapa")
}

model InteraccionMapa {
  id              Int             @id @default(autoincrement())
  tipo            TipoInteraccion
  latitudMomento  Decimal?        @db.Decimal(10, 7)
  longitudMomento Decimal?        @db.Decimal(10, 7)
  zoomMomento     Int?
  ocurrioEn       DateTime        @default(now())
  sesionId        Int
  marcadorId      Int
  marcador        MarcadorMapa    @relation(fields: [marcadorId], references: [id], onDelete: Cascade)
  sesion          SesionMapa      @relation(fields: [sesionId], references: [id], onDelete: Cascade)

  @@map("interaccion_mapa")
}

model BannerHome {
  id            Int      @id @default(autoincrement())
  urlImagen     String
  orden         Int
  activo        Boolean  @default(true)
  fechaCreacion DateTime @default(now())
  titulo        String?
  subtitulo     String?

  @@map("banner_home")
}

model Visitor {
  id          Int      @id @default(autoincrement())
  ip          String
  metaData    Json?
  fechaVisita DateTime @default(now())
  usuarioId   Int?
  usuario     Usuario? @relation(fields: [usuarioId], references: [id])

  @@map("visitor")
}

model public_Telefono {
  id         Int     @id @default(autoincrement())
  numero     String
  usuarioId  Int
  codigoPais String
  principal  Boolean

  @@map("Telefono")
}

model ubicacion_maestra {
  id                 Int                 @id @default(autoincrement())
  departamento       String
  provincia          String?
  municipio          String?
  nombre             String
  latitud            Decimal             @db.Decimal(10, 7)
  longitud           Decimal             @db.Decimal(10, 7)
  popularidad        Int                 @default(0)
  ubicacion_inmueble UbicacionInmueble[]

  @@index([nombre])
}

model PagoQr {
  id               Int      @id @default(autoincrement())
  monto            Float
  codigoReferencia String   @unique
  estado           String
  usuarioId        Int
  fechaCreacion    DateTime @default(now())
}

model bitacora_pagos {
  id               Int               @id @default(autoincrement())
  id_usuario       Int?
  id_suscripcion   Int?
  id_transaccion   Int?
  evento           String            @db.VarChar(100)
  mensaje          String?
  fecha_evento     DateTime?         @default(now()) @db.Timestamp(6)
  plan_suscripcion plan_suscripcion? @relation(fields: [id_suscripcion], references: [id], onUpdate: NoAction)
  transacciones    transacciones?    @relation(fields: [id_transaccion], references: [id], onUpdate: NoAction)
  usuario          Usuario?          @relation(fields: [id_usuario], references: [id], onUpdate: NoAction)

  @@index([fecha_evento], map: "idx_bitacora_fecha_evento")
  @@index([id_transaccion], map: "idx_bitacora_transaccion_id")
}

model plan_suscripcion {
  id                     Int                     @id @default(autoincrement())
  nombre_plan            String                  @db.VarChar(50)
  descripcion_plan       String?
  precio_plan            Decimal                 @db.Decimal(10, 2)
  duracion_plan_dias     Int
  nro_publicaciones_plan Int
  bitacora_pagos         bitacora_pagos[]
  suscripciones_activas  suscripciones_activas[]
  transacciones          transacciones[]
}

model suscripciones_activas {
  id               Int               @id @default(autoincrement())
  id_usuario       Int?
  id_suscripcion   Int?
  id_transaccion   Int?
  fecha_inicio     DateTime          @db.Timestamp(6)
  fecha_fin        DateTime          @db.Timestamp(6)
  estado           String?           @default("INACTIVA") @db.VarChar(20)
  plan_suscripcion plan_suscripcion? @relation(fields: [id_suscripcion], references: [id], onDelete: NoAction, onUpdate: NoAction)
  transacciones    transacciones?    @relation(fields: [id_transaccion], references: [id], onDelete: NoAction, onUpdate: NoAction)
  usuario          Usuario?          @relation(fields: [id_usuario], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model transacciones {
  id                     Int                     @id @default(autoincrement())
  id_usuario             Int
  id_suscripcion         Int
  subtotal               Decimal                 @db.Decimal(10, 2)
  iva_porcentaje         Decimal                 @db.Decimal(5, 2)
  iva_monto              Decimal                 @db.Decimal(10, 2)
  total                  Decimal                 @db.Decimal(10, 2)
  metodo_pago            String?                 @default("QR_BANCARIO") @db.VarChar(30)
  qr_texto               String?
  qr_url                 String?
  fecha_intento          DateTime?               @default(now()) @db.Timestamp(6)
  fecha_completado       DateTime?               @db.Timestamp(6)
  estado                 String?                 @default("PENDIENTE") @db.VarChar(20)
  verificacion_requerida Boolean?                @default(true)
  tiempo_activacion      DateTime?               @db.Timestamp(6)
  bitacora_pagos         bitacora_pagos[]
  suscripciones_activas  suscripciones_activas[]
  plan_suscripcion       plan_suscripcion        @relation(fields: [id_suscripcion], references: [id], onDelete: NoAction, onUpdate: NoAction)
  usuario                Usuario                 @relation(fields: [id_usuario], references: [id], onDelete: NoAction, onUpdate: NoAction)
  verificacion_pago      verificacion_pago[]

  @@index([estado], map: "idx_transacciones_estado")
  @@index([id_usuario], map: "idx_transacciones_usuario_id")
}

model verificacion_pago {
  id                     Int            @id @default(autoincrement())
  id_transaccion         Int?
  id_admin               Int
  fecha_verificacion     DateTime?      @default(now()) @db.Timestamp(6)
  resultado_verificacion String?        @default("VERIFICADO") @db.VarChar(20)
  usuario                Usuario        @relation(fields: [id_admin], references: [id], onDelete: NoAction, onUpdate: NoAction)
  transacciones          transacciones? @relation(fields: [id_transaccion], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

enum Genero {
  MASCULINO
  FEMENINO
  OTRO
}

enum TipoAccion {
  VENTA
  ALQUILER
  ANTICRETO
}

enum EstadoInmueble {
  ACTIVO
  INACTIVO
  VENDIDO
  ALQUILADO
  RESERVADO
}

enum EstadoPublicacion {
  ACTIVA
  PAUSADA
  ELIMINADA
}

enum Categoria {
  CASA
  DEPARTAMENTO
  TERRENO
  OFICINA
}

enum RolNombre {
  ADMIN
  PROPIETARIO
  AGENTE
  VISITANTE
}

enum TipoMultimedia {
  IMAGEN
  VIDEO
}

enum TipoMarcador {
  NORMAL
  DESTACADO
  CLUSTER
}

enum TipoInteraccion {
  CLICK
  HOVER
  ZOOM
  DRAG
}
